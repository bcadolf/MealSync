@page "/recipes/create"
@using MealSync.Core.Entities
@using MealSync.Core.Interfaces
@inject IRecipeService RecipeService
@inject NavigationManager Navigation

<PageTitle>Create Recipe</PageTitle>

<h1>Create Recipe</h1>

<hr />
<div class="row">
    <div class="col-md-4">
        <EditForm Model="@recipe" OnValidSubmit="HandleValidSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="form-group mb-3">
                <label for="Title" class="control-label">Title</label>
                <InputText id="Title" class="form-control" @bind-Value="recipe.Title" />
            </div>

            <div class="form-group mb-3">
                <label for="Description" class="control-label">Description</label>
                <InputTextArea id="Description" class="form-control" @bind-Value="recipe.Description" />
            </div>

            <div class="form-group mb-3">
                <label for="Instructions" class="control-label">Instructions</label>
                <InputTextArea id="Instructions" class="form-control" @bind-Value="recipe.Instructions" />
            </div>

            <div class="form-group mb-3">
                <label for="PrepTime" class="control-label">Prep Time (min)</label>
                <InputNumber id="PrepTime" class="form-control" @bind-Value="recipe.PrepTime" />
            </div>

            <div class="form-group mb-3">
                <label for="CookTime" class="control-label">Cook Time (min)</label>
                <InputNumber id="CookTime" class="form-control" @bind-Value="recipe.CookTime" />
            </div>

            <div class="form-group mb-3">
                <label for="Servings" class="control-label">Servings</label>
                <InputNumber id="Servings" class="form-control" @bind-Value="recipe.Servings" />
            </div>

            <div class="form-group form-check mb-3">
                <label class="form-check-label">
                    <InputCheckbox class="form-check-input" @bind-Value="recipe.IsPublic" /> Is Public
                </label>
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-primary">Create</button>
            </div>
        </EditForm>
    </div>
</div>

<div>
    <a href="/recipes">Back to List</a>
</div>

@code {
    private Recipe recipe = new Recipe();

    private async Task HandleValidSubmit()
    {
        await RecipeService.CreateRecipeAsync(recipe);
        Navigation.NavigateTo("/recipes");
    }
}
